# Database
DATABASE_URL=postgresql+asyncpg://freelaas:freelaas123@db:5432/freelaas

# Alibaba Cloud Model Studio (Qwen)
DASHSCOPE_API_KEY=your_dashscope_api_key_here
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Model selection per agent
MODEL_SCANNER=qwen2.5-7b-instruct-1m
MODEL_ANALYST=qwen-plus-2025-07-28
MODEL_STRATEGIST=qwen3-max

# Scraper
SCRAPE_INTERVAL_MINUTES=3
SCRAPE_MAX_PAGES=3
SCRAPE_DELAY_MIN=10
SCRAPE_DELAY_MAX=20
TIME_FILTER_MINUTES=10000

# Logging
LOG_LEVEL=INFO

# WAHA Integration
WAHA_API_URL=http://localhost:3005
WAHA_API_KEY=your_waha_api_key_here
WAHA_SESSION=default
WAHA_PHONE_NUMBER=your_group_jid_or_phone@g.us
WAHA_DASHBOARD_USERNAME=admin
WAHA_DASHBOARD_PASSWORD=your_dashboard_password_here
WHATSAPP_SWAGGER_USERNAME=admin
WHATSAPP_SWAGGER_PASSWORD=your_swagger_password_here

# Timezone
TZ=America/Sao_Paulo

# Action System — Kill Switch (true = Playwright envia automaticamente)
AUTO_ACTION_ENABLED=false
